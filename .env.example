DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
NODE_ENV=development
PORT=3000

# Workspace / JWT (zorunlu)
JWT_SECRET=change-me-to-a-long-random-string

# İlerleme JSON dosyaları (repo köküne göre göreli yol)
PROGRESS_SUMMARY_PATH=data/progress_summary.json
PROGRESS_DETAIL_PATH=data/progress_from_results.json

# CORS: virgülle birden fazla origin; boş veya * = tüm originler (geliştirme)
# Örnek: CORS_ORIGINS=http://localhost:3000,https://panel.example.com
CORS_ORIGINS=

# Swagger UI yolu (varsayilan api): http://localhost:PORT/api
SWAGGER_PATH=api

# AWS S3 uploads
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Upload multipart behavior
# Varsayilan: 24 saat
UPLOAD_SESSION_TTL_MS=86400000
# Varsayilan: 15 dakika
UPLOADS_PART_URL_EXPIRES_SECONDS=900
# Her cleanup calismasinda islenecek en fazla stale session sayisi
UPLOADS_CLEANUP_BATCH_SIZE=100
# Varsayilan: her 30 dakikada bir
# Cron formati: second minute hour day-of-month month day-of-week
UPLOADS_CLEANUP_CRON=0 */30 * * * *
