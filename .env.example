DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
NODE_ENV=development
PORT=3000

# Workspace / JWT (zorunlu)
JWT_SECRET=change-me-to-a-long-random-string

# İlerleme JSON dosyaları (repo köküne göre göreli yol)
PROGRESS_SUMMARY_PATH=data/progress_summary.json
PROGRESS_DETAIL_PATH=data/progress_from_results.json

# CORS: virgülle birden fazla origin; boş veya * = tüm originler (geliştirme)
# Örnek: CORS_ORIGINS=http://localhost:3000,https://panel.example.com
CORS_ORIGINS=

# Swagger UI yolu (varsayilan api): http://localhost:PORT/api
SWAGGER_PATH=api
